# MADFAM Private Package Registry — scoped packages route through npm.madfam.io
# (Verdaccio). Auth token is injected at install time:
#   - locally:  set NPM_MADFAM_TOKEN env var or add `//npm.madfam.io/:_authToken=...` to ~/.npmrc
#   - in CI:    workflow steps `echo "//npm.madfam.io/:_authToken=${{ secrets.NPM_MADFAM_TOKEN }}" >> .npmrc`
# Internal `@cotiza/*` packages are resolved via the pnpm workspace and don't hit the registry.
@madfam:registry=https://npm.madfam.io
@dhanam:registry=https://npm.madfam.io
@janua:registry=https://npm.madfam.io
@cotiza:registry=https://npm.madfam.io
@fortuna:registry=https://npm.madfam.io
@avala:registry=https://npm.madfam.io
@forgesight:registry=https://npm.madfam.io
@coforma:registry=https://npm.madfam.io
@forj:registry=https://npm.madfam.io
