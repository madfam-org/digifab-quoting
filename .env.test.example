# CI test environment template — copied to .env.test by the workflow's
# `Setup test database` step. Not committed-into-test-runs values; CI
# overrides via job env (DATABASE_URL, REDIS_URL, JWT_SECRET).

NODE_ENV=test

# Database — CI Postgres service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=test_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test_db?schema=public

# Redis — CI service container
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT — deterministic test secret, never a real secret
JWT_SECRET=test-jwt-secret-not-for-prod
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
NEXTAUTH_SECRET=test-nextauth-secret-not-for-prod
NEXTAUTH_URL=http://localhost:3030

# Janua — bypass in tests, no real OIDC validation
JANUA_JWKS_URI=https://auth.madfam.io/.well-known/jwks.json
JANUA_ISSUER=https://auth.madfam.io
JANUA_CLIENT_ID=cotiza-studio-test
JANUA_CLIENT_SECRET=test-only

# Auth fallback for tests that don't go through Janua
ENABLE_LOCAL_AUTH=true

# S3 / R2 — CI uses local mock, never real bucket
S3_BUCKET=cotiza-test
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT=http://localhost:9000

# Stripe — CI uses test keys, never live
STRIPE_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_test_dummy

# Currency / locale defaults
DEFAULT_CURRENCY=MXN
SUPPORTED_CURRENCIES=MXN,USD
DEFAULT_LOCALES=es,en
FX_SOURCE=disabled

# Webhook secrets — tests skip signature verification when blank
FORGESIGHT_WEBHOOK_SECRET=
YANTRA4D_API_URL=http://localhost:9999
YANTRA4D_WEBHOOK_SECRET=
DHANAM_WEBHOOK_URL=http://localhost:9999
DHANAM_WEBHOOK_SECRET=

# Phase D outbound integrations — CI never hits real endpoints
KARAFIEL_API_URL=http://localhost:9999
KARAFIEL_SERVICE_TOKEN=test
KARAFIEL_EMISOR_RFC=TEST000000000
KARAFIEL_CREDENTIAL_ID=test-credential
KARAFIEL_WEBHOOK_TIMEOUT=1000
DHANAM_API_URL=http://localhost:9999
DHANAM_BILLING_SECRET=test
DHANAM_WEBHOOK_TIMEOUT=1000
PRAVARA_API_URL=http://localhost:9999
PRAVARA_DISPATCH_SECRET=test
PRAVARA_WEBHOOK_TIMEOUT=1000

# PhyneCRM engagement projection — inbound test secret
PHYNECRM_INBOUND_SECRET=test-phynecrm-inbound
PHYNECRM_ENGAGEMENT_SECRET=test-phynecrm-outbound
