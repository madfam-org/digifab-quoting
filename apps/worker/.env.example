# FastAPI Worker Configuration
# Placeholder-only template. Production/staging values must come from Enclii
# secrets backed by Lockbox/Vault/ESO.
PORT=8000
WORKERS=4
LOG_LEVEL=info
PYTHONUNBUFFERED=1

# Database
DATABASE_URL=replace-with-local-or-secret-store-database-url

# Redis Queue
REDIS_URL=redis://localhost:6379
QUEUE_NAME=geometry-analysis

# S3 Configuration
AWS_REGION=us-east-1
S3_BUCKET=cotiza-quoting-uploads
S3_ACCESS_KEY_ID=replace-with-s3-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-s3-secret-access-key

# Analysis Settings
MAX_FILE_SIZE_MB=100
ANALYSIS_TIMEOUT_SECONDS=120

# Geometry Analysis Libraries (when implemented)
OPENCASCADE_PATH=/usr/local/lib/opencascade
FREECAD_PATH=/usr/bin/freecad

# Performance
MAX_CONCURRENT_ANALYSES=10
MEMORY_LIMIT_MB=2048

# Feature Flags
ENABLE_MESH_REPAIR=true
ENABLE_WALL_THICKNESS_CHECK=true
ENABLE_SUPPORT_DETECTION=true
ENABLE_TOOLPATH_SIMULATION=false
