# Environment
NODE_ENV=development
PORT=3030

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_TIMEOUT=30000

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# Public URLs
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_DOMAIN=cotiza.studio

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# File Upload
NEXT_PUBLIC_MAX_FILE_SIZE_MB=100
NEXT_PUBLIC_ACCEPTED_FILE_TYPES=.stl,.step,.stp,.iges,.igs,.dxf,.pdf

# Localization
NEXT_PUBLIC_DEFAULT_LOCALE=es
NEXT_PUBLIC_SUPPORTED_LOCALES=es,en

# Feature Flags
NEXT_PUBLIC_ENABLE_CHAT_SUPPORT=false
NEXT_PUBLIC_ENABLE_3D_VIEWER=true
NEXT_PUBLIC_ENABLE_INSTANT_QUOTE=true

# PMF Widget (RFC 0013) — gated until @madfam/pmf-widget publishes + is installed
# Default false; flip to true after operator runs `npm install @madfam/pmf-widget@^0.1.0`
NEXT_PUBLIC_PMF_WIDGET_ENABLED=false
NEXT_PUBLIC_TULANA_API_URL=https://api.tulana.madfam.io

# Company Info
NEXT_PUBLIC_COMPANY_NAME=MADFAM
NEXT_PUBLIC_COMPANY_EMAIL=innovacionescotiza@proton.me
NEXT_PUBLIC_COMPANY_WEBSITE=https://cotiza.io

# SEO
NEXT_PUBLIC_SITE_TITLE=Cotiza.Studio - Fabricación Digital al Instante
NEXT_PUBLIC_SITE_DESCRIPTION=Obtén cotizaciones instantáneas para impresión 3D, mecanizado CNC y corte láser