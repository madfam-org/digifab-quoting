# Root environment variables for docker-compose and development.
# Placeholder-only template. Production/staging values must come from Enclii
# secrets backed by Lockbox/Vault/ESO, not copied docs or chat transcripts.

# Environment
NODE_ENV=development

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_DB=cotiza_quoting
DATABASE_URL=replace-with-local-or-secret-store-database-url

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=replace-with-local-redis-password

# JWT & Auth
JWT_SECRET=replace-with-local-jwt-secret
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
NEXTAUTH_SECRET=replace-with-local-nextauth-secret
NEXTAUTH_URL=http://localhost:3030

# Janua OIDC Configuration
JANUA_JWKS_URI=https://auth.madfam.io/.well-known/jwks.json
JANUA_ISSUER=https://auth.madfam.io
JANUA_CLIENT_ID=replace-with-janua-client-id
JANUA_CLIENT_SECRET=replace-with-janua-client-secret

# Local auth fallback (set to true for development without Janua)
ENABLE_LOCAL_AUTH=false

# AWS
AWS_REGION=us-east-1
S3_BUCKET=cotiza-quoting-dev
S3_REGION=us-east-1
KMS_KEY_ID=

# SQS
SQS_QUEUE_URL=

# Janua Multi-Provider Billing
# Routes to Conekta (MX) or Polar (international) based on country
JANUA_BILLING_ENABLED=true
JANUA_API_URL=http://janua-api:8001
JANUA_API_KEY=replace-with-janua-api-key
JANUA_WEBHOOK_SECRET=replace-with-janua-webhook-secret

# Dhanam Integration (billing events webhook)
DHANAM_WEBHOOK_SECRET=replace-with-dhanam-webhook-secret
DHANAM_WEBHOOK_URL=replace-with-dhanam-webhook-url

# Email
EMAIL_FROM=innovacionescotiza@proton.me
SES_REGION=us-east-1

# Defaults
DEFAULT_CURRENCY=MXN
DEFAULT_LOCALE=es
QUOTE_VALIDITY_DAYS=14

# FX Provider
FX_PROVIDER=openexchangerates
FX_API_KEY=replace-with-fx-api-key-if-used

# See PORT_REGISTRY.md in solarpunk-foundry for port assignments
WEB_PORT=3030
API_PORT=4030
WORKER_PORT=8100

# Worker
GEOMETRY_SERVICE_URL=http://localhost:8100

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4030/api/v1

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3030,http://localhost:4030

# Domains
API_DOMAIN=api.cotiza.studio
WEB_DOMAIN=cotiza.studio

# Company
COMPANY_EMAIL=innovacionescotiza@proton.me
COMPANY_DOMAIN=cotiza.io

# Local Development
USE_LOCALSTACK=true
LOCALSTACK_ENDPOINT=http://localhost:4566

# Feature Flags
FEATURE_SUPPLIER_PORTAL=false
FEATURE_QUOTE_COMPARISON=false
FEATURE_ADVANCED_DFM=false
